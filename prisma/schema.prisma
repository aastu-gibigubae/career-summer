// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum STATUS {
  approved
  rejected
  pending
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String

  @@map("users")
}

model Applicant {
  id               String           @id @default(cuid())
  fullName         String
  email            String
  phoneNumber      String
  year             Int
  tgUsername       String
  cv               String
  agileMethodology Boolean
  ITTeam           Boolean
  status           STATUS           @default(pending)
  skill            ApplicantSkill[]

  @@map("applicants")
}

model Skill {
  id   String           @id @default(cuid())
  name String           @unique
  user ApplicantSkill[]

  @@map("skills")
}

model ApplicantSkill {
  skillId     String
  applicantId String
  skill       Skill     @relation(fields: [skillId], references: [id])
  applicant   Applicant @relation(fields: [applicantId], references: [id])

  @@id([applicantId, skillId])
  @@map("applicantSkills")
}
